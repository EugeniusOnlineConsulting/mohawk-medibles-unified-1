// Mohawk Medibles — Enterprise Database Schema
// Prisma schema for Postgres/SQLite development
// Covers: Products, Customers, Orders, Inventory, Blog, Roles

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── Authentication & Roles ─────────────────────────────────

model User {
    id            String    @id @default(cuid())
    email         String    @unique
    passwordHash  String
    name          String
    phone         String?
    role          Role      @default(CUSTOMER)
    avatar        String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    lastLogin     DateTime?

    // Relations
    orders        Order[]
    addresses     Address[]
    sessions      Session[]
    supportTickets SupportTicket[]
    reviews       Review[]

    @@index([email])
    @@index([role])
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())
    user      User     @relation(fields: [userId], references: [id])

    @@index([token])
}

enum Role {
    CUSTOMER
    SUPPORT
    LOGISTICS
    ADMIN
    SUPER_ADMIN
}

model Address {
    id         String  @id @default(cuid())
    userId     String
    label      String  @default("Home")
    firstName  String
    lastName   String
    street1    String
    street2    String?
    city       String
    province   String
    postalCode String
    country    String  @default("CA")
    phone      String?
    isDefault  Boolean @default(false)

    user   User    @relation(fields: [userId], references: [id])
    orders Order[]

    @@index([userId])
}

// ─── Product Reviews ────────────────────────────────────────

model Review {
    id        Int          @id @default(autoincrement())
    productId Int
    userId    String
    rating    Int          // 1-5
    title     String?
    content   String
    verified  Boolean      @default(false) // true if user has purchased this product
    status    ReviewStatus @default(PENDING)
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt

    product Product @relation(fields: [productId], references: [id])
    user    User    @relation(fields: [userId], references: [id])

    @@index([productId])
    @@index([userId])
    @@index([status])
}

enum ReviewStatus {
    PENDING
    APPROVED
    REJECTED
}

// ─── Products & Inventory ───────────────────────────────────

model Product {
    id              Int       @id @default(autoincrement())
    wcId            Int?      @unique  // WooCommerce ID
    slug            String    @unique
    name            String
    shortName       String?
    category        String
    subcategory     String?
    price           Float     @default(0)
    salePrice       Float?
    sku             String?
    canonicalUrl    String
    path            String
    image           String
    altText         String
    metaDescription String
    shortDescription String
    longDescription String?
    featured        Boolean   @default(false)
    status          ProductStatus @default(ACTIVE)
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    // Relations
    specs       ProductSpec?
    inventory   Inventory?
    orderItems  OrderItem[]
    images      ProductImage[]
    reviews     Review[]

    @@index([category])
    @@index([slug])
    @@index([status])
}

model ProductSpec {
    id        Int      @id @default(autoincrement())
    productId Int      @unique
    thc       String?
    cbd       String?
    type      String?
    weight    String?
    terpenes  String?  // JSON array stored as string
    lineage   String?
    eeatNarrative String?

    product Product @relation(fields: [productId], references: [id])
}

model ProductImage {
    id        Int     @id @default(autoincrement())
    productId Int
    url       String
    altText   String?
    position  Int     @default(0)

    product Product @relation(fields: [productId], references: [id])

    @@index([productId])
}

model Inventory {
    id          Int      @id @default(autoincrement())
    productId   Int      @unique
    quantity    Int      @default(0)
    lowStockAt  Int      @default(5)
    backorder   Boolean  @default(false)
    updatedAt   DateTime @updatedAt

    product Product @relation(fields: [productId], references: [id])
}

enum ProductStatus {
    ACTIVE
    DRAFT
    OUT_OF_STOCK
    DISCONTINUED
}

// ─── Orders & Transactions ──────────────────────────────────

model Order {
    id              String      @id @default(cuid())
    wcOrderId       Int?        @unique  // WooCommerce order ID
    orderNumber     String      @unique
    userId          String
    addressId       String?
    status          OrderStatus @default(PENDING)
    subtotal        Float
    shippingCost    Float       @default(0)
    tax             Float       @default(0)
    discount        Float       @default(0)
    total           Float
    currency        String      @default("CAD")
    paymentMethod   String?
    paymentStatus   PaymentStatus @default(PENDING)
    notes           String?
    customerNote    String?
    ipAddress       String?

    // ShipStation fields
    shipstationId   String?     @unique
    trackingNumber  String?
    carrier         String?
    shippingLabel   String?     // URL to label PDF
    shippedAt       DateTime?
    deliveredAt     DateTime?

    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt

    // Relations
    user          User        @relation(fields: [userId], references: [id])
    address       Address?    @relation(fields: [addressId], references: [id])
    items         OrderItem[]
    statusHistory OrderStatusHistory[]
    supportTickets SupportTicket[]

    @@index([userId])
    @@index([status])
    @@index([orderNumber])
    @@index([createdAt])
}

model OrderItem {
    id        String @id @default(cuid())
    orderId   String
    productId Int
    quantity  Int
    price     Float
    total     Float
    name      String    // Snapshot of product name at time of order

    order   Order   @relation(fields: [orderId], references: [id])
    product Product @relation(fields: [productId], references: [id])

    @@index([orderId])
}

model OrderStatusHistory {
    id        String      @id @default(cuid())
    orderId   String
    status    OrderStatus
    note      String?
    changedBy String?    // User ID who made the change
    createdAt DateTime   @default(now())

    order Order @relation(fields: [orderId], references: [id])

    @@index([orderId])
}

enum OrderStatus {
    PENDING
    PROCESSING
    PAYMENT_CONFIRMED
    LABEL_PRINTED
    SHIPPED
    IN_TRANSIT
    DELIVERED
    COMPLETED
    CANCELLED
    REFUNDED
    ON_HOLD
    FAILED
}

enum PaymentStatus {
    PENDING
    PAID
    PARTIALLY_REFUNDED
    REFUNDED
    FAILED
}

// ─── Support & Voice Agent ──────────────────────────────────

model SupportTicket {
    id          String       @id @default(cuid())
    userId      String
    orderId     String?
    subject     String
    status      TicketStatus @default(OPEN)
    priority    Priority     @default(NORMAL)
    channel     String       @default("voice")  // voice, chat, email
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    resolvedAt  DateTime?

    user     User    @relation(fields: [userId], references: [id])
    order    Order?  @relation(fields: [orderId], references: [id])
    messages TicketMessage[]

    @@index([userId])
    @@index([status])
}

model TicketMessage {
    id        String   @id @default(cuid())
    ticketId  String
    sender    String   // "customer", "agent", "bot"
    content   String
    createdAt DateTime @default(now())

    ticket SupportTicket @relation(fields: [ticketId], references: [id])

    @@index([ticketId])
}

enum TicketStatus {
    OPEN
    IN_PROGRESS
    WAITING_CUSTOMER
    RESOLVED
    CLOSED
}

enum Priority {
    LOW
    NORMAL
    HIGH
    URGENT
}

// ─── Blog & Content ─────────────────────────────────────────

model BlogPost {
    id              Int      @id @default(autoincrement())
    wcPostId        Int?     @unique
    slug            String   @unique
    title           String
    excerpt         String?
    content         String
    featuredImage   String?
    author          String?
    status          String   @default("published")
    category        String?
    tags            String?  // JSON array
    seoTitle        String?
    seoDescription  String?
    seoKeywords     String?  // JSON array of target keywords
    canonicalUrl    String?
    publishedAt     DateTime?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([slug])
    @@index([category])
}

model Page {
    id          Int    @id @default(autoincrement())
    wcPageId    Int?   @unique
    slug        String @unique
    title       String
    content     String
    template    String?
    seoTitle    String?
    seoDescription String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([slug])
}

// ─── Coupons & Discounts ────────────────────────────────────

model Coupon {
    id            Int       @id @default(autoincrement())
    code          String    @unique
    description   String?
    type          DiscountType @default(PERCENTAGE)
    value         Float        // percentage (e.g. 10.0) or flat amount (e.g. 5.00)
    minOrderTotal Float?       // minimum cart total to qualify
    maxUses       Int?         // null = unlimited
    usedCount     Int          @default(0)
    perCustomer   Int          @default(1) // max uses per customer
    validFrom     DateTime     @default(now())
    validUntil    DateTime?
    active        Boolean      @default(true)
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt

    @@index([code])
    @@index([active])
}

enum DiscountType {
    PERCENTAGE
    FIXED_AMOUNT
    FREE_SHIPPING
}

// ─── API Keys (for admin-managed service credentials) ───────

model ApiKey {
    id          String   @id @default(cuid())
    service     String   // e.g. "stripe", "shipstation", "resend", "openai", "google"
    label       String   // e.g. "Stripe Live", "Stripe Test"
    keyValue    String   // encrypted or masked value
    environment String   @default("development") // "development" | "production"
    isActive    Boolean  @default(true)
    lastUsed    DateTime?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([service, environment])
    @@index([service])
}

// ─── Admin Audit Log ────────────────────────────────────────

model AuditLog {
    id        String   @id @default(cuid())
    userId    String
    action    String   // e.g. "product.create", "order.update-status", "settings.api-key-change"
    entity    String?  // e.g. "Product", "Order"
    entityId  String?  // ID of the affected entity
    details   String?  // JSON details of the change
    ipAddress String?
    createdAt DateTime @default(now())

    @@index([userId])
    @@index([action])
    @@index([createdAt])
}

// ─── Newsletter Subscribers ─────────────────────────────────

model Subscriber {
    id          String   @id @default(cuid())
    email       String   @unique
    name        String?
    status      String   @default("active") // active, unsubscribed, bounced
    source      String?  // "checkout", "popup", "footer", "agent"
    segments    String?  // JSON array: ["VIP", "edibles-buyer", "flower-lover"]
    metadata    String?  // JSON: {"lastOrderDate": "...", "totalSpend": 0, "orderCount": 0}
    subscribedAt DateTime @default(now())
    unsubscribedAt DateTime?

    @@index([email])
    @@index([status])
}

// ─── Email Campaigns ─────────────────────────────────────────

model Campaign {
    id            String         @id @default(cuid())
    name          String
    subject       String
    previewText   String?
    htmlContent   String         // Full email HTML body
    status        CampaignStatus @default(DRAFT)
    segmentRules  String?        // JSON: {"segment":"VIP","minSpend":500}
    scheduledAt   DateTime?
    sentAt        DateTime?
    totalSent     Int            @default(0)
    totalOpened   Int            @default(0)
    totalClicked  Int            @default(0)
    totalBounced  Int            @default(0)
    createdBy     String?
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    sends CampaignSend[]

    @@index([status])
    @@index([scheduledAt])
}

model CampaignSend {
    id          String    @id @default(cuid())
    campaignId  String
    email       String
    status      String    @default("pending") // pending, sent, delivered, opened, clicked, bounced, failed
    sentAt      DateTime?
    openedAt    DateTime?
    clickedAt   DateTime?

    campaign Campaign @relation(fields: [campaignId], references: [id])

    @@index([campaignId])
    @@index([email])
}

enum CampaignStatus {
    DRAFT
    SCHEDULED
    SENDING
    SENT
    CANCELLED
}

// ─── Content Calendar ────────────────────────────────────────

model ContentPiece {
    id          String    @id @default(cuid())
    channel     String    // instagram, twitter_x, blog, email, gmb
    pillar      String    // education, product_story, heritage, behind_scenes, community
    title       String?
    content     String    // Generated content (JSON for structured, HTML for blog/email)
    productId   Int?
    keyword     String?
    status      String    @default("draft") // draft, scheduled, published, archived
    scheduledAt DateTime?
    publishedAt DateTime?
    metrics     String?   // JSON: {"views":0,"clicks":0,"engagement":0}
    createdBy   String?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([channel])
    @@index([status])
    @@index([scheduledAt])
}

// ─── SEO & Keywords ─────────────────────────────────────────

model Keyword {
    id          Int    @id @default(autoincrement())
    term        String @unique
    volume      Int?
    difficulty  Int?
    currentRank Int?
    targetUrl   String?
    category    String?
    intent      String?  // informational, transactional, navigational
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([term])
    @@index([category])
}

// ═══════════════════════════════════════════════════════════
// ═══ AI-POWERED DIRECTORY MODELS ═══════════════════════════
// ═══════════════════════════════════════════════════════════

// ─── AI Directory: Dispensaries ─────────────────────────────

model Dispensary {
    id                String   @id @default(cuid())
    name              String
    slug              String   @unique
    description       String?  @db.Text
    descriptionAi     String?  @db.Text  // AI-generated description
    
    // Location
    address           String
    city              String
    province          String
    postalCode        String
    latitude          Float?
    longitude         Float?
    
    // Contact
    phone             String?
    email             String?
    website           String?
    
    // Business Info
    isIndigenousOwned Boolean  @default(false)
    isFirstNations    Boolean  @default(false)
    isLicensed        Boolean  @default(true)
    licenseNumber     String?
    
    // Ratings & Reviews
    averageRating     Float    @default(0)
    reviewCount       Int      @default(0)
    
    // AI Metadata
    aiConfidence      Float    @default(0.0)  // Data confidence score
    lastAiUpdate      DateTime @default(now())
    dataQualityScore  Int      @default(0)    // 0-100
    
    // SEO
    metaTitle         String?
    metaDescription   String?
    keywords          String[] // AI-extracted keywords
    
    // Google My Business Sync
    gmbLocationId     String?  @unique  // GMB location ID for syncing
    lastGmbSync       DateTime?         // Last sync timestamp
    
    // Relations
    hours             BusinessHours[]
    reviews           DispensaryReview[]
    products          DispensaryProduct[]
    images            DispensaryImage[]
    
    // Timestamps
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    
    // Indexes for performance
    @@index([city, province])
    @@index([isIndigenousOwned])
    @@index([isFirstNations])
    @@index([dataQualityScore])
    @@index([averageRating])
}

model BusinessHours {
    id           String   @id @default(cuid())
    dispensaryId String
    dayOfWeek    Int      // 0 = Sunday, 6 = Saturday
    openTime     String?  // "09:00"
    closeTime    String?  // "21:00"
    isClosed     Boolean  @default(false)
    
    dispensary Dispensary @relation(fields: [dispensaryId], references: [id], onDelete: Cascade)
    
    @@index([dispensaryId])
}

model DispensaryReview {
    id            String   @id @default(cuid())
    dispensaryId  String
    rating        Int      // 1-5
    title         String?
    content       String   @db.Text
    authorName    String?
    verified      Boolean  @default(false)
    
    // AI Analysis
    sentiment     String?  // positive, negative, neutral
    aiResponse    String?  @db.Text  // Auto-generated response
    keyTopics     String[] // AI-extracted topics
    
    createdAt     DateTime @default(now())
    
    dispensary Dispensary @relation(fields: [dispensaryId], references: [id], onDelete: Cascade)
    
    @@index([dispensaryId])
    @@index([sentiment])
    @@index([createdAt])
}

model DispensaryProduct {
    id             String   @id @default(cuid())
    dispensaryId   String
    name           String
    category       String   // flower, edibles, concentrates, etc.
    strainType     String?  // indica, sativa, hybrid
    thcContent     String?
    cbdContent     String?
    price          Float?
    priceUnit      String?  // gram, eighth, ounce, etc.
    inStock        Boolean  @default(true)
    
    // AI
    aiDescription  String?  @db.Text
    aiTags         String[]
    
    dispensary Dispensary @relation(fields: [dispensaryId], references: [id], onDelete: Cascade)
    
    @@index([dispensaryId])
    @@index([category])
    @@index([inStock])
}

model DispensaryImage {
    id           String   @id @default(cuid())
    dispensaryId String
    url          String
    altText      String?
    isPrimary    Boolean  @default(false)
    
    dispensary Dispensary @relation(fields: [dispensaryId], references: [id], onDelete: Cascade)
    
    @@index([dispensaryId])
}

// ─── AI Directory: City Pages ───────────────────────────────

model CityPage {
    id                String   @id @default(cuid())
    city              String
    province          String
    slug              String   @unique
    
    // AI Content
    content           String   @db.Text  // Main page content
    contentAi         String?  @db.Text  // AI-generated content
    faq               Json?    // Structured FAQ data
    localInsights     Json?    // AI-generated local insights
    
    // SEO
    metaTitle         String
    metaDescription   String
    keywords          String[]
    
    // Statistics
    dispensaryCount   Int      @default(0)
    indigenousCount   Int      @default(0)
    avgRating         Float?
    
    // Relations
    featuredDispensaries String[] // Array of dispensary IDs
    
    // Timestamps
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    
    @@unique([city, province])
    @@index([city, province])
    @@index([dispensaryCount])
}

// ─── AI Directory: Blog & Content ───────────────────────────

model AIBlogPost {
    id              String   @id @default(cuid())
    slug            String   @unique
    title           String
    content         String   @db.Text
    excerpt         String?
    
    // AI Metadata
    aiGenerated     Boolean  @default(true)
    aiModel         String?  // GPT-4, Claude, etc.
    aiPrompt        String?  @db.Text
    
    // SEO
    metaTitle       String?
    metaDescription String?
    keywords        String[]
    targetKeyword   String?
    
    // Content Attributes
    category        String
    tags            String[]
    readTime        Int?     // minutes
    
    // Status
    status          String   @default("draft") // draft, published, archived
    publishedAt     DateTime?
    
    // Relations
    faqContent      AIFAQ[]
    
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
    
    @@index([status])
    @@index([category])
    @@index([publishedAt])
    @@index([targetKeyword])
}

model AIFAQ {
    id          String   @id @default(cuid())
    blogPostId  String?
    cityPageId  String?
    
    question    String
    answer      String   @db.Text
    
    // AI
    aiGenerated Boolean  @default(true)
    confidence  Float?
    
    // Schema
    schemaMarkup Json?   // Structured data
    
    // Relations
    blogPost    AIBlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
    
    createdAt   DateTime @default(now())
    
    @@index([blogPostId])
    @@index([cityPageId])
}

// ─── AI Directory: Automation Logs ──────────────────────────

model AIAutomationLog {
    id          String   @id @default(cuid())
    agentName   String   // Which AI agent ran
    action      String   // What was done
    status      String   // success, failed, partial
    details     Json?    // Additional data
    itemCount   Int?     // How many items processed
    durationMs  Int?     // How long it took
    
    createdAt   DateTime @default(now())
    
    @@index([agentName])
    @@index([status])
    @@index([createdAt])
}

// ─── AI Directory: Price Tracking ───────────────────────────

model PriceTracking {
    id            String   @id @default(cuid())
    productName   String
    category      String
    dispensaryId  String?
    
    price         Float
    currency      String   @default("CAD")
    pricePerGram  Float?   // Normalized price
    
    source        String   // Where price was found
    sourceUrl     String?
    
    recordedAt    DateTime @default(now())
    
    @@index([productName])
    @@index([category])
    @@index([dispensaryId])
    @@index([recordedAt])
}

// ─── AI Directory: Entity Knowledge Graph ───────────────────

model Entity {
    id          String   @id @default(cuid())
    name        String
    type        String   // dispensary, strain, product, location, person
    
    attributes  Json?    // Flexible attributes
    
    // Relations (self-referential for knowledge graph)
    outgoingRelations EntityRelation[] @relation("FromEntity")
    incomingRelations EntityRelation[] @relation("ToEntity")
    
    // AI
    aiSummary   String?  @db.Text
    confidence  Float    @default(1.0)
    
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    @@index([name])
    @@index([type])
}

model EntityRelation {
    id          String   @id @default(cuid())
    
    fromEntityId String
    toEntityId   String
    relationType String   // e.g., "locatedIn", "sells", "produces"
    
    confidence  Float    @default(1.0)
    
    fromEntity  Entity   @relation("FromEntity", fields: [fromEntityId], references: [id])
    toEntity    Entity   @relation("ToEntity", fields: [toEntityId], references: [id])
    
    @@index([fromEntityId])
    @@index([toEntityId])
    @@index([relationType])
}

// ═══════════════════════════════════════════════════════════
// ═══ END AI DIRECTORY MODELS ═══════════════════════════════
// ═══════════════════════════════════════════════════════════
