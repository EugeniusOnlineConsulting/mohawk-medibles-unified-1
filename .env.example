# Mohawk Medibles — Environment Configuration
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values.

# ─── Database (PostgreSQL — Neon) ────────────────────────────
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"

# ─── WooCommerce REST API ───────────────────────────────────
WC_STORE_URL="https://mohawkmedibles.ca"
WC_CONSUMER_KEY="ck_xxx"
WC_CONSUMER_SECRET="cs_xxx"
WC_WEBHOOK_SECRET=""  # Optional: HMAC secret for WC webhook verification

# ─── Authentication ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET="CHANGE-ME-generate-a-64-byte-hex-string"

# ─── ShipStation ─────────────────────────────────────────────
SHIPSTATION_API_KEY=""
SHIPSTATION_API_SECRET=""
SHIPSTATION_WEBHOOK_SECRET=""

# ─── Payments (Stripe) ──────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Google Pay ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MERCHANT_ID=""

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="orders@mohawkmedibles.ca"

# ─── Agent Gateway ───────────────────────────────────────────
AGENT_GATEWAY_URL="http://localhost:8000"
AGENT_API_SECRET=""  # Shared secret for Python agents → Next.js API auth (falls back to AUTH_SECRET)
NEXTJS_URL="http://localhost:3000"  # Used by Python agents to call Next.js API routes

# ─── Competitor Intelligence (Manus / SimilarWeb) ───────────
MANUS_API_URL=""
MANUS_API_KEY=""

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
GOOGLE_SITE_VERIFICATION=""

# ─── Error Monitoring (Sentry) ──────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://mohawkmedibles.ca"
NODE_ENV="development"
